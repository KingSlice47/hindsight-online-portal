---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Pricing | Hindsight Consulting"
  description="Transparent pricing for our financial and compliance solutions. Choose the plan that fits your business needs."
  pageClass="page-pricing"
  currentPage="pricing"
>
  <!-- Hero Section -->
  <section class="hero-section pricing-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-text">
        <h1 class="hero-title fade-in-up">
          <span class="text-primary">Pricing Made Simple</span>
        </h1>
        <p class="hero-subtitle fade-in-up stagger-1">
          Transparent plans, clear choices. Find the perfect solution for your business needs.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="pricing-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Choose Your <span class="text-primary">Plan</span></h2>
        <p class="section-subtitle">
          All plans include our core accounting and compliance services
        </p>
      </div>

      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="plan-header">
            <h3>Starter</h3>
            <div class="price">
              <span class="currency">R</span>
              <span class="amount">1,500</span>
              <span class="period">/month</span>
            </div>
          </div>
          <ul class="plan-features">
            <li>Basic bookkeeping</li>
            <li>Monthly financial statements</li>
            <li>VAT submissions</li>
            <li>Email support</li>
          </ul>
          <a href="/contact" class="btn btn-outline">Get Started</a>
        </div>

        <div class="pricing-card featured">
          <div class="popular-badge">Most Popular</div>
          <div class="plan-header">
            <h3>Professional</h3>
            <div class="price">
              <span class="currency">R</span>
              <span class="amount">2,500</span>
              <span class="period">/month</span>
            </div>
          </div>
          <ul class="plan-features">
            <li>Complete bookkeeping</li>
            <li>Monthly financial statements</li>
            <li>VAT & PAYE submissions</li>
            <li>Income tax returns</li>
            <li>Business registration support</li>
            <li>Phone & email support</li>
          </ul>
          <a href="/contact" class="btn btn-primary">Get Started</a>
        </div>

        <div class="pricing-card">
          <div class="plan-header">
            <h3>Enterprise</h3>
            <div class="price">
              <span class="currency">R</span>
              <span class="amount">4,000</span>
              <span class="period">/month</span>
            </div>
          </div>
          <ul class="plan-features">
            <li>Full accounting services</li>
            <li>Financial statement compilation</li>
            <li>Complete tax compliance</li>
            <li>Business administration</li>
            <li>Tender opportunities</li>
            <li>Priority support</li>
            <li>Dedicated account manager</li>
          </ul>
          <a href="/contact" class="btn btn-outline">Get Started</a>
        </div>
      </div>

      <!-- Additional Services -->
      <div class="additional-services">
        <h3>Additional Services</h3>
        <div class="services-grid">
          <div class="service-item">
            <h4>Social Media Management</h4>
            <p>R800/month - Professional social media presence across all platforms</p>
          </div>
          <div class="service-item">
            <h4>Website Development</h4>
            <p>From R5,000 - Custom website design and development</p>
          </div>
          <div class="service-item">
            <h4>Mobile Apps</h4>
            <p>R500/month - Access to our mobile accounting and HR applications</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <h3>What's included in all plans?</h3>
          <p>All plans include basic bookkeeping, monthly financial statements, and email support. Higher
            tiers add more comprehensive services.</p>
        </div>
        <div class="faq-item">
          <h3>Can I upgrade my plan?</h3>
          <p>Yes, you can upgrade or downgrade your plan at any time. Changes take effect at the next
            billing cycle.</p>
        </div>
        <div class="faq-item">
          <h3>Do you offer custom solutions?</h3>
          <p>Absolutely! We can tailor our services to meet your specific business requirements. Contact
            us for a custom quote.</p>
        </div>
        <div class="faq-item">
          <h3>What payment methods do you accept?</h3>
          <p>We accept bank transfers, debit orders, and credit card payments for your convenience.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Get Started?</h2>
        <p>Choose your plan and let us help you streamline your business operations today.</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary">
            Contact Us Today
          </a>
          <a href="tel:+27721610801" class="btn btn-secondary">
            Call: 072 161 0801
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
