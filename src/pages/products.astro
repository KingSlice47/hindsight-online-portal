---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Our Services | Hindsight Consulting"
  description="Comprehensive financial and business solutions for South African SMEs including accounting, tax services, and business administration."
  pageClass="page-products"
  currentPage="products"
>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-text">
        <h1 class="hero-title fade-in-up">
          Our <span class="text-primary">Services</span>
        </h1>
        <p class="hero-subtitle fade-in-up stagger-1">
          Comprehensive financial and business solutions designed to help South African SMEs thrive
          in today's competitive marketplace.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Our <span class="text-primary">Services</span></h2>
        <p class="section-subtitle">Comprehensive financial and business solutions designed to help South
          African SMEs thrive</p>
      </div>

      <div class="services-grid">
        <div class="service-card" data-service="accounting">
          <div class="service-image">
            <img src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
              alt="Accounting and Bookkeeping Services" loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Accounting & Bookkeeping</h3>
            <p>Comprehensive financial record keeping and accounting services tailored for SMEs.</p>
            <ul class="service-features">
              <li><span class="feature-icon">✓</span>Monthly financial statements</li>
              <li><span class="feature-icon">✓</span>Transaction recording</li>
              <li><span class="feature-icon">✓</span>Bank reconciliations</li>
              <li><span class="feature-icon">✓</span>Financial reporting</li>
            </ul>
            <a href="/contact" class="service-btn">Learn More</a>
          </div>
        </div>

        <div class="service-card" data-service="tax">
          <div class="service-image">
            <img src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
              alt="Tax Services and Compliance" loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Tax Services</h3>
            <p>Complete tax compliance including VAT, PAYE, Income Tax, and SARS eFiling services.</p>
            <ul class="service-features">
              <li><span class="feature-icon">✓</span>VAT submissions</li>
              <li><span class="feature-icon">✓</span>PAYE processing</li>
              <li><span class="feature-icon">✓</span>Income tax returns</li>
              <li><span class="feature-icon">✓</span>SARS eFiling support</li>
            </ul>
            <a href="/contact" class="service-btn">Learn More</a>
          </div>
        </div>

        <div class="service-card" data-service="financial">
          <div class="service-image">
            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
              alt="Financial Statement Compilation" loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Financial Statement Compilation</h3>
            <p>Professional financial statement preparation using Draftworx for accurate reporting.</p>
            <ul class="service-features">
              <li><span class="feature-icon">✓</span>Annual financial statements</li>
              <li><span class="feature-icon">✓</span>Management accounts</li>
              <li><span class="feature-icon">✓</span>Compliance reporting</li>
              <li><span class="feature-icon">✓</span>Audit preparation</li>
            </ul>
            <a href="/contact" class="service-btn">Learn More</a>
          </div>
        </div>

        <div class="service-card" data-service="administration">
          <div class="service-image">
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
              alt="Business Administration Services" loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Business Administration</h3>
            <p>Complete business compliance including CIPC, COIDA, NCR, and FSCA registrations.</p>
            <ul class="service-features">
              <li><span class="feature-icon">✓</span>Company registrations</li>
              <li><span class="feature-icon">✓</span>Compliance monitoring</li>
              <li><span class="feature-icon">✓</span>Regulatory submissions</li>
              <li><span class="feature-icon">✓</span>License applications</li>
            </ul>
            <a href="/contact" class="service-btn">Learn More</a>
          </div>
        </div>

        <div class="service-card" data-service="tender">
          <div class="service-image">
            <img src="https://images.unsplash.com/photo-1560472354-b33ff0c44a43?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
              alt="Tender Opportunities Management" loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Tender Opportunities</h3>
            <p>Identification and management of tender opportunities through eTenders portal access.</p>
            <ul class="service-features">
              <li><span class="feature-icon">✓</span>Tender identification</li>
              <li><span class="feature-icon">✓</span>Proposal assistance</li>
              <li><span class="feature-icon">✓</span>Compliance checking</li>
              <li><span class="feature-icon">✓</span>Submission support</li>
            </ul>
            <a href="/contact" class="service-btn">Learn More</a>
          </div>
        </div>

        <div class="service-card" data-service="social">
          <div class="service-image">
            <img src="https://images.unsplash.com/photo-1611224923853-80b023f02d71?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
              alt="Social Media Management" loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Social Media Engagement</h3>
            <p>Professional social media management across LinkedIn, Facebook, and Instagram platforms.</p>
            <ul class="service-features">
              <li><span class="feature-icon">✓</span>Content creation</li>
              <li><span class="feature-icon">✓</span>Community management</li>
              <li><span class="feature-icon">✓</span>Brand engagement</li>
              <li><span class="feature-icon">✓</span>Analytics reporting</li>
            </ul>
            <a href="/contact" class="service-btn">Learn More</a>
          </div>
        </div>

        <div class="service-card" data-service="mobile">
          <div class="service-image">
            <img src="https://images.unsplash.com/photo-1563986768609-322da13575f3?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
              alt="Mobile Business Solutions" loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Mobile Solutions</h3>
            <p>Mobile-first applications for accounting and HR management on the go.</p>
            <ul class="service-features">
              <li><span class="feature-icon">✓</span>Mobile accounting</li>
              <li><span class="feature-icon">✓</span>HR management</li>
              <li><span class="feature-icon">✓</span>Real-time updates</li>
              <li><span class="feature-icon">✓</span>Cloud synchronization</li>
            </ul>
            <a href="/contact" class="service-btn">Learn More</a>
          </div>
        </div>

        <div class="service-card" data-service="digital">
          <div class="service-image">
            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
              alt="Digital Services and Web Development" loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Digital Services via Afrilink Telecoms</h3>
            <p>Complete digital solutions including web development, hosting, and email services.</p>
            <ul class="service-features">
              <li><span class="feature-icon">✓</span>Website development</li>
              <li><span class="feature-icon">✓</span>Domain & hosting</li>
              <li><span class="feature-icon">✓</span>Email solutions</li>
              <li><span class="feature-icon">✓</span>Technical support</li>
            </ul>
            <a href="/contact" class="service-btn">Learn More</a>
          </div>
        </div>
      </div>

      <!-- Service Statistics -->
      <div class="service-stats">
        <div class="stat-item">
          <div class="stat-number">500+</div>
          <div class="stat-label">Clients Served</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">98%</div>
          <div class="stat-label">Client Satisfaction</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">24/7</div>
          <div class="stat-label">Cloud Access</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">100%</div>
          <div class="stat-label">SARS Compliant</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Transform Your Business?</h2>
        <p>Let us help you streamline your financial processes and achieve compliance with ease.</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary">
            Get Started Today
          </a>
          <a href="tel:+27721610801" class="btn btn-secondary">
            Call Us: 072 161 0801
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
